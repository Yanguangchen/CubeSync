# Local development template.
# Copy this file to .env.local, then replace the placeholder values.
#
# Vercel Project Settings:
# - Name: CUBESYNC_RECAPTCHA_SITE_KEY
#   Value: your-recaptcha-v2-site-key
# - Name: CUBESYNC_RECAPTCHA_SECRET_KEY
#   Value: your-recaptcha-v2-secret-key
# - Name: FIREBASE_SERVICE_ACCOUNT_JSON
#   Value: paste ONLY the JSON object below, without the FIREBASE_SERVICE_ACCOUNT_JSON= prefix.

CUBESYNC_RECAPTCHA_SITE_KEY=your-recaptcha-v2-site-key
CUBESYNC_RECAPTCHA_SECRET_KEY=your-recaptcha-v2-secret-key

# Multiline JSON is supported locally by scripts/load-env.js.
# Keep private_key as one JSON string with \n newline escapes.
FIREBASE_SERVICE_ACCOUNT_JSON={
  "type": "service_account",
  "project_id": "your-firebase-project-id",
  "private_key_id": "your-private-key-id",
  "private_key": "-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_LINE_1\nYOUR_PRIVATE_KEY_LINE_2\n-----END PRIVATE KEY-----\n",
  "client_email": "firebase-adminsdk-example@your-firebase-project-id.iam.gserviceaccount.com",
  "client_id": "your-client-id",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-example%40your-firebase-project-id.iam.gserviceaccount.com",
  "universe_domain": "googleapis.com"
}

# Optional alternative for Vercel if multiline JSON paste causes escaping issues.
# Base64 encode the full downloaded service-account JSON file and set this
# instead of FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
